Screen {
    background: #0d1117;
}

#app-container {
    border: round #30363d;
    padding: 0 1;
    height: 100%;
}

Header {
    background: #161b22;
    color: #c9d1d9;
    height: 1;
}

#main-container {
    height: 1fr;
}

/* ---- left column ---- */

#left-column {
    width: 2fr;
    height: 100%;
    padding: 0 1 0 0;
}

#chat-history {
    height: 1fr;
    border: round #30363d;
    padding: 1;
    margin-bottom: 1;
}

#chat-messages {
    height: 1fr;
    background: #0d1117;
    color: #c9d1d9;
    border: none;
    padding: 0 1;
    overflow-y: auto;
}

#chat-input-area {
    height: auto;
    dock: bottom;
}

#prompt-input {
    height: 5;
    min-height: 5;
    max-height: 10;
    border: round #30363d;
    padding: 1;
    background: #0d1117;
    color: #c9d1d9;
}

#prompt-input:focus {
    border: round #58a6ff;
}

#approve-btn {
    display: none;
    height: 3;
    margin-top: 1;
}

/* ---- right column ---- */

#right-column {
    width: 1fr;
    height: 100%;
    padding: 0 0 0 0;
}

#process-tabs {
    height: 3fr;
    margin-bottom: 1;
}

#process-tabs TabbedContent {
    background: #0d1117;
}

#process-tabs TabbedContent > Vertical {
    background: #0d1117;
}

#process-tabs TabPane {
    padding: 1;
}

#file-autocomplete {
    height: auto;
    max-height: 10;
    display: none;
    border: round #58a6ff;
    background: #161b22;
    margin-bottom: 0;
    padding: 0;
}

#file-autocomplete:focus {
    border: round #58a6ff;
}

#file-autocomplete ListItem {
    padding: 0 1;
    color: #c9d1d9;
}

#file-autocomplete ListItem.autocomplete-highlighted {
    background: #1f6feb;
    color: #ffffff;
}

#file-autocomplete ListItem:hover {
    background: #1f6feb33;
}

#errors-output, #state-output {
    background: #0d1117;
    color: #c9d1d9;
    border: none;
    padding: 1;
}

#models-panel {
    height: 2fr;
    border: round #30363d;
    padding: 1;
}

.panel-label {
    color: #8b949e;
    text-style: bold;
    margin-bottom: 1;
}

/* ---- model config panel ---- */

#model-config-rows {
    height: 1fr;
    overflow-y: auto;
}

.model-config-row {
    height: 3;
    margin-bottom: 1;
}

.model-config-label {
    width: auto;
    min-width: 10;
    color: #8b949e;
    padding: 0 1;
    text-style: bold;
}

.model-config-row Select {
    width: 1fr;
    background: #161b22;
    color: #c9d1d9;
    border: round #30363d;
}

.model-config-row Select:focus {
    border: round #58a6ff;
}

.model-config-row Select > .select-current {
    color: #c9d1d9;
}

.model-config-row Select > .select-dropdown {
    background: #161b22;
    color: #c9d1d9;
}

#model-loading {
    color: #8b949e;
    margin: 1 1;
}

/* ---- status bar ---- */

#status-bar {
    height: 1;
    background: #21262d;
    color: #8b949e;
    padding: 0 1;
}
